# ================================
# SMALL runtime artifacts
# ================================

# Root workspace canonical artifacts are committed, so do NOT ignore /.small/ entirely.
.small-cache/
.small-runs/
.small-archive/

# Legacy pre-hardening runtime layout (ignored until migrated)
.small/runs/
.small/archive/

# Examples are fixtures, not runtime noise
!/examples/**/.small/
!/examples/**/.small/**
examples/**/.small-cache/
examples/**/.small-runs/
examples/**/.small-archive/
examples/**/.small/runs/
examples/**/.small/archive/

# JCN universal secrets policy
.env
.env.*
!.env.example
!.env.sample
!.env.template
!.env.*.example
!.env.*.sample
!.env.*.template
